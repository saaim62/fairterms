{
  "name": "fairterms-extension",
  "displayName": "FairTerms",
  "version": "0.0.1",
  "license": "MIT",
  "description": "Browser extension that instantaneously analyzes Terms of Service and contracts, highlighting exploitative clauses (arbitration waivers, data rights, auto-renewal traps) in simple traffic-light warnings before signing.",
  "author": "Zeeshan Zafar",
  "scripts": {
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build",
    "build:chromium": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "build:safari": "plasmo build --target=safari-mv3",
    "package": "plasmo package",
    "postinstall": "node scripts/copy-pdf-worker.cjs"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "lucide-react": "^1.7.0",
    "pdfjs-dist": "4.10.38",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prettier": "3.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "scripting",
      "tabs"
    ],
    "host_permissions": [
      "https://*/*",
      "http://*/*",
      "file://*/*"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "assets/pdf.worker.min.mjs"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ]
  }
}
