# Groq (OpenAI-compatible API). Get a key at https://console.groq.com/
GROQ_API_KEY=

# Optional: default llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: max characters sent to the model (default 9000; Groq free tier TPM often needs smaller payloads)
# GROQ_MAX_INPUT_CHARS=9000

# Console: log full LLM JSON body (1) or preview only (default ~800 chars)
# FAIRTERMS_LOG_LLM_FULL=1
# FAIRTERMS_LOG_LLM_PREVIEW=1200

# Multilingual: auto-detect document language for extra regex banks (24 locales + English base = 25 languages).
# Codes: es de fr zh hi ar pt ru ur bn ja ko tr id vi it nl pl th sw fa ms tl uk
# Set 0 to disable detection (Latin-based extras like es/de/pt then rely on script hints or FAIRTERMS_RULE_LOCALES).
# FAIRTERMS_DETECT_LANGUAGE=1
# Force pattern locales (comma-separated); overrides detection. Example: zh,ja,ko
# FAIRTERMS_RULE_LOCALES=
# When detection misses CJK/Arabic/etc., add script-based locale hints for regex banks (default on). Set 0 to disable.
# FAIRTERMS_SCRIPT_LOCALE_HINT=1
# Groq: same_as_input (default) or en — label/explanation language vs English
# FAIRTERMS_EXPLANATION_LANGUAGE=same_as_input
# CORS: comma-separated allowed origins. If unset: "*" outside production; in production
# (FAIRTERMS_ENV=production) no wildcard — you must set this (e.g. chrome-extension://...).
# FAIRTERMS_ENV=production
# FAIRTERMS_CORS_ORIGINS=chrome-extension://your-extension-id

# Rate limit POST /analyze per client IP (slowapi; in-memory — use Redis-backed limits for multi-node).
# FAIRTERMS_RATE_LIMIT_ENABLED=1
# FAIRTERMS_RATE_LIMIT_ANALYZE=30/minute
